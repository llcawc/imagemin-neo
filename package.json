{
  "name": "imagemin-neo",
  "version": "10.0.0",
  "description": "Minify images seamlessly",
  "keywords": [
    "compress",
    "gif",
    "image",
    "images",
    "jpeg",
    "jpg",
    "minify",
    "png",
    "svg"
  ],
  "homepage": "https://github.com/llcawc/imagemin-neo",
  "license": "MIT",
  "author": {
    "name": "imagemin",
    "url": "https://github.com/imagemin"
  },
  "maintainers": [
    "llcawc by pasmurno"
  ],
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest --run",
    "lint": "oxlint",
    "fix": "oxlint --fix",
    "check": "oxfmt --check",
    "fmt": "oxfmt",
    "typecheck": "tsc -p . --noEmit",
    "validate": "oxlint && tsc --noEmit",
    "start": "node test/imgrun.js && node test/imgbuf.js && node test/imglob.js",
    "build": "tsdown"
  },
  "dependencies": {
    "file-type": "^22.0.1",
    "p-limit": "^6.0.0",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260423.1",
    "imagemin-jpegtran": "^8.0.0",
    "imagemin-svgo": "^12.0.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
